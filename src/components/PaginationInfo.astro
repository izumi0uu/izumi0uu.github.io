---
import type { PaginationProps } from "@/types/common";
import * as m from "@/paraglide/messages";

export interface Props extends PaginationProps {
  className?: string;
}

const { start, end, total, currentPage, lastPage, className = "" } = Astro.props;

const startItem = start + 1;
const endItem = end + 1;
---

<div class={`text-sm text-content-secondary flex items-center gap-4 ${className}`}>
  <span>
    {m["components.pagination.showing_items"]({
      start: startItem.toString(),
      end: endItem.toString(),
      total: total.toString(),
    })}
  </span>
  <span class="text-xs">
    {m["components.pagination.page_of"]({
      current: currentPage.toString(),
      last: lastPage.toString(),
    })}
  </span>
</div>
