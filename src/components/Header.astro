---
import { NavigationBar } from "@/components/react/ui/NavigationBar";
import { Separator } from "@/components/react/radix-ui/Separator";
import { SELECTORS } from "@/constants/dom";
import { LOCALE_LABELS, LOCAL_STORAGE_KEY, LOCALE_NOTICE_STORAGE_KEY } from "@/config/i18n";
import { CONFIG_CLIENT } from "@/config/client";
import { ROUTES } from "@/constants/routes";
import { getAllPostsWithReadingTime } from "@/modules/post/common";
import { getAllProjects } from "@/modules/project/common";
import { getPathWithLocale } from "@/utils/routing/paths";
import * as m from "@/paraglide/messages";

import type { LocaleSwitchTarget } from "@/types/common";
import type { LocaleValues } from "@/types/config";

export interface HeaderProps {
  currentLocale: LocaleValues;
  localeSwitch?: LocaleSwitchTarget;
}

const { currentLocale, localeSwitch } = Astro.props as HeaderProps;
const [posts, projects] = await Promise.all([getAllPostsWithReadingTime(), getAllProjects()]);

const { SCROLL_TO_TOP_ID } = SELECTORS;
const homeHref = getPathWithLocale(currentLocale, ROUTES.HOME);
const navLinks = [
  {
    key: "blog",
    href: getPathWithLocale(currentLocale, ROUTES.BLOG),
    text: m["components.navigation_menu.blog_link"](),
  },
  {
    key: "project",
    href: getPathWithLocale(currentLocale, ROUTES.PROJECT),
    text: m["components.navigation_menu.project_link"](),
  },
  {
    key: "experience",
    href: getPathWithLocale(currentLocale, ROUTES.EXPERIENCE),
    text: m["components.navigation_menu.experience_link"](),
  },
  {
    key: "about",
    href: getPathWithLocale(currentLocale, ROUTES.ABOUT),
    text: m["components.navigation_menu.about_link"](),
  },
];

const pageItems = [
  {
    value: `page:${currentLocale}:home`,
    label: m["components.navigation_menu.home_link"](),
    href: getPathWithLocale(currentLocale, ROUTES.HOME),
  },
  {
    value: `page:${currentLocale}:blog`,
    label: m["components.navigation_menu.blog_link"](),
    href: getPathWithLocale(currentLocale, ROUTES.BLOG),
  },
  {
    value: `page:${currentLocale}:project`,
    label: m["components.navigation_menu.project_link"](),
    href: getPathWithLocale(currentLocale, ROUTES.PROJECT),
  },
  {
    value: `page:${currentLocale}:experience`,
    label: m["components.navigation_menu.experience_link"](),
    href: getPathWithLocale(currentLocale, ROUTES.EXPERIENCE),
  },
  {
    value: `page:${currentLocale}:about`,
    label: m["components.navigation_menu.about_link"](),
    href: getPathWithLocale(currentLocale, ROUTES.ABOUT),
  },
].map((item) => ({
  ...item,
  detail: item.href,
  keywords: [item.label, item.href, currentLocale],
}));

const postItems = posts
  .slice()
  .sort((left, right) => Number(right.locale === currentLocale) - Number(left.locale === currentLocale))
  .map((post) => {
    const href = getPathWithLocale(post.locale, `${ROUTES.BLOG}${post.slug}`);
    const tags = post.data.tags ?? [];
    const category = post.data.category ? [post.data.category] : [];

    return {
      value: `post:${post.locale}:${post.slug}`,
      label: post.data.title,
      href,
      detail: `${LOCALE_LABELS[post.locale]} · ${href}`,
      keywords: [
        post.data.title,
        post.data.description ?? "",
        post.slug,
        post.translationKey,
        LOCALE_LABELS[post.locale],
        ...tags,
        ...category,
      ],
    };
  });

const projectItems = projects
  .slice()
  .sort(
    (left, right) => Number(right.locale === currentLocale) - Number(left.locale === currentLocale)
  )
  .map((project) => {
    const href = getPathWithLocale(project.locale, `${ROUTES.PROJECT}${project.slug}`);
    const tags = project.data.tags ?? [];

    return {
      value: `project:${project.locale}:${project.slug}`,
      label: project.data.title,
      href,
      detail: `${LOCALE_LABELS[project.locale]} · ${href}`,
      keywords: [
        project.data.title,
        project.data.description ?? "",
        project.slug,
        project.translationKey,
        LOCALE_LABELS[project.locale],
        ...tags,
      ],
    };
  });

const searchBox = {
  placeholder: m["components.search_box.placeholder"](),
  tipsPlaceholder: m["components.search_box.tips_placeholder"](),
  noResults: m["components.search_box.no_results"](),
  sections: [
    {
      heading: m["components.navigation_menu.blog_link"](),
      icon: "blog",
      items: postItems,
    },
    {
      heading: m["components.navigation_menu.project_link"](),
      icon: "project",
      items: projectItems,
    },
    {
      heading: m["components.navigation_menu.links_link"](),
      icon: "page",
      items: pageItems,
    },
  ],
};

const themeSwitcher = {
  label: m["components.theme_switcher.label"](),
  cancelLabel: m["components.theme_switcher.cancel"](),
  themeLabels: {
    default: m["components.theme_switcher.themes.default"](),
    wine: m["components.theme_switcher.themes.wine"](),
  },
} as const;
---

<!-- TODO: FIX SCROLL TO TOP -->
<header
  class="flex flex-col gap-2 fixed top-0 right-0 left-0 z-50 backdrop-blur-sm"
  id={SCROLL_TO_TOP_ID}
>
  <NavigationBar
    client:load
    authorName={CONFIG_CLIENT.AUTHOR_NAME}
    homeHref={homeHref}
    homeLabel={m["components.navigation_menu.home_link"]()}
    navLinks={navLinks}
    themeLabel={m["components.navigation_menu.theme_label"]()}
    languageLabel={m["components.navigation_menu.language_label"]()}
    {searchBox}
    {themeSwitcher}
    localeSwitch={localeSwitch && {
      ...localeSwitch,
      targetLabel: LOCALE_LABELS[localeSwitch.targetLocale],
      preferredLocaleStorageKey: LOCAL_STORAGE_KEY,
      noticeStorageKey: LOCALE_NOTICE_STORAGE_KEY,
      buttonTitle: m["components.locale_switch.switch_to"]({
        locale: LOCALE_LABELS[localeSwitch.targetLocale],
      }),
      missingTranslationTitle: m["components.locale_switch.missing_translation_title"](),
      missingTranslationDescription: m["components.locale_switch.missing_translation_description"]({
        locale: LOCALE_LABELS[localeSwitch.targetLocale],
      }),
    }}
  />
  <Separator client:load />
</header>
