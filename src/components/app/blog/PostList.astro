---
import PostCard from "@/components/app/blog/PostCard.astro";
import * as m from "@/paraglide/messages";

import type { Post } from "@/types/post";

export interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<div class="flex-col-layout-center gap-2">
  {posts.length > 0 ? posts.map((post) => <PostCard post={post} />) : <p>{m["components.lists.empty_posts"]()}</p>}
</div>
