---
import { DEFAULT_LOCALE, LOCAL_STORAGE_KEY, SUPPORTED_LOCALES } from "@/config/i18n";

const defaultHref = `/${DEFAULT_LOCALE}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0;url=${defaultHref}`} />
    <title>Redirecting...</title>
  </head>
  <body>
    <a href={defaultHref}>Redirecting to {defaultHref}</a>

    <script
      is:inline
      define:vars={{
        defaultHref,
        storageKey: LOCAL_STORAGE_KEY,
        supportedLocales: SUPPORTED_LOCALES,
      }}
    >
      const search = window.location.search ?? "";
      const hash = window.location.hash ?? "";

      let targetHref = defaultHref;

      try {
        const preferredLocale = localStorage.getItem(storageKey);

        if (preferredLocale && supportedLocales.includes(preferredLocale)) {
          targetHref = `/${preferredLocale}/`;
        } else if (preferredLocale) {
          localStorage.removeItem(storageKey);
        }
      } catch (error) {
        console.warn("Unable to resolve preferred locale:", error);
      }

      window.location.replace(`${targetHref}${search}${hash}`);
    </script>
  </body>
</html>
