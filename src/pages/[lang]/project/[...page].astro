---
import { getAllProjects } from "@/modules/project/common";
import List from "@/layouts/List.astro";
import ProjectList from "@/components/app/project/ProjectList.astro";
import { CONFIG_CLIENT } from "@/config/client";
import { ROUTES } from "@/constants/routes";
import { getPageMetadata } from "@/utils/content/metadata";
import { pickPaginationPropsFromPage } from "@/utils/content/pagination";
import { SUPPORTED_LOCALES } from "@/config/i18n";
import { getPathWithLocale } from "@/utils/routing/paths";

import type { LocaleAlternate, LocaleSwitchTarget, PaginationProps } from "@/types/common";
import type { LocaleValues } from "@/types/config";
import type { Project } from "@/types/project";
import type { GetStaticPathsOptions } from "astro";

function getProjectPagePath(locale: LocaleValues, pageNumber: number) {
  return pageNumber === 1
    ? getPathWithLocale(locale, ROUTES.PROJECT)
    : getPathWithLocale(locale, `${ROUTES.PROJECT}${pageNumber}/`);
}

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const getStaticProjectPagePath = (locale: LocaleValues, pageNumber: number) =>
    pageNumber === 1
      ? getPathWithLocale(locale, ROUTES.PROJECT)
      : getPathWithLocale(locale, `${ROUTES.PROJECT}${pageNumber}/`);
  const allProjects: Project[] = await getAllProjects();
  const pageSize = CONFIG_CLIENT.PAGE_SIZE_PROJECT_CARD;
  const projectsByLocale = Object.fromEntries(
    SUPPORTED_LOCALES.map((locale) => [
      locale,
      allProjects.filter((project) => project.locale === locale),
    ])
  ) as Record<LocaleValues, Project[]>;
  const getPageCount = (locale: LocaleValues) =>
    Math.ceil(projectsByLocale[locale].length / pageSize);

  const paths = [];

  for (const lang of SUPPORTED_LOCALES) {
    const localizedProjects = projectsByLocale[lang];
    const targetLocale = SUPPORTED_LOCALES.find((locale) => locale !== lang) ?? lang;

    if (localizedProjects.length === 0) {
      const alternates = SUPPORTED_LOCALES.map((locale) => ({
        locale,
        href: getStaticProjectPagePath(locale, 1),
      }));

      paths.push({
        params: { lang },
        props: {
          projects: [],
          alternates,
          localeSwitch: {
            currentLocale: lang,
            targetLocale,
            href: getStaticProjectPagePath(targetLocale, 1),
            missingTranslation: false,
          },
        },
      });

      continue;
    }

    const paginatedPaths = paginate(localizedProjects, {
      pageSize,
      params: { lang },
    });

    paths.push(
      ...paginatedPaths.map((path) => {
        const currentPage = path.props.page.currentPage;
        const targetPageCount = getPageCount(targetLocale);
        const hasEquivalentTargetPage = currentPage === 1 || targetPageCount >= currentPage;
        const alternates = SUPPORTED_LOCALES.filter((locale) => {
          const localePageCount = getPageCount(locale);
          return currentPage === 1 || localePageCount >= currentPage;
        }).map((locale) => ({
          locale,
          href: getStaticProjectPagePath(locale, currentPage),
        }));

        return {
          params: path.params,
          props: {
            projects: path.props.page.data,
            paginationProps: pickPaginationPropsFromPage(path.props.page),
            alternates,
            localeSwitch: {
              currentLocale: lang,
              targetLocale,
              href: hasEquivalentTargetPage
                ? getStaticProjectPagePath(targetLocale, currentPage)
                : getStaticProjectPagePath(targetLocale, 1),
              missingTranslation: false,
            },
          },
        };
      })
    );
  }

  return paths;
}

const {
  projects,
  paginationProps,
  alternates,
  localeSwitch,
} = Astro.props as {
  projects: Project[];
  paginationProps?: PaginationProps;
  alternates: LocaleAlternate[];
  localeSwitch: LocaleSwitchTarget;
};

const metadata = getPageMetadata("lists/project");
const currentLocale = Astro.params.lang as LocaleValues;
const currentPath = getProjectPagePath(currentLocale, paginationProps?.currentPage ?? 1);
---

<List
  {metadata}
  {paginationProps}
  {alternates}
  {localeSwitch}
  {currentLocale}
  currentPath={currentPath}
>
  <ProjectList projects={projects} />
</List>
