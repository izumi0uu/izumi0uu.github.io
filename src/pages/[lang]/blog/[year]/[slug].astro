---
import { Image } from "astro:assets";
import { render } from "astro:content";

import { getAllPostsWithReadingTime } from "@/modules/post/common";
import { getRandomPosts } from "@/modules/post/random";
import { getYearSlugRouteParams } from "@/modules/common";

import { default as PostLayout } from "@/layouts/Post.astro";
import PostMeta from "@/components/app/blog/PostMeta.astro";
import Skeleton from "@/components/Skeleton.astro";

import { DRAFT_TEXT } from "@/constants/data";
import { IMAGE_SIZES } from "@/constants/image";
import { ROUTES } from "@/constants/routes";
import { setTransitionSlug, TRANSITION_ELEMENT_IDS } from "@/constants/transitions";
import { getLocaleSwitchTarget } from "@/utils/routing/navigation";
import { getPathWithLocale } from "@/utils/routing/paths";
import * as m from "@/paraglide/messages";

import type { Metadata } from "@/types/common";
import type { LocaleValues } from "@/types/config";
import type { Post, PostCollection } from "@/types/post";

function getPostPath(locale: LocaleValues, slug: string) {
  return getPathWithLocale(locale, `${ROUTES.BLOG}${slug}`);
}

export async function getStaticPaths() {
  const getStaticPostPath = (locale: LocaleValues, slug: string) =>
    getPathWithLocale(locale, `${ROUTES.BLOG}${slug}`);
  const posts = await getAllPostsWithReadingTime();
  const postsByTranslationKey = posts.reduce((map, post) => {
    const siblings = map.get(post.translationKey) ?? [];
    siblings.push(post);
    map.set(post.translationKey, siblings);
    return map;
  }, new Map<string, Post[]>());

  return posts.map((post) => {
    const siblings = postsByTranslationKey.get(post.translationKey) ?? [post];
    const alternates = siblings.map((sibling) => ({
      locale: sibling.locale,
      href: getStaticPostPath(sibling.locale, sibling.slug),
    }));
    const localeSwitch = getLocaleSwitchTarget({
      currentLocale: post.locale,
      alternates,
      fallbackFactory: (locale) => getPathWithLocale(locale, ROUTES.HOME),
    });
    const randomPosts = getRandomPosts({
      posts: posts.filter((candidate) => candidate.locale === post.locale),
      excludeSlug: post.slug,
    });
    const routeParams = getYearSlugRouteParams(post.slug, post.id);

    return {
      params: {
        lang: post.locale,
        ...routeParams,
      },
      props: {
        post,
        alternates,
        localeSwitch,
        randomPosts,
      },
    };
  });
}

const {
  post,
  randomPosts,
  alternates,
  localeSwitch,
} = Astro.props as {
  post: Post;
  randomPosts: Post[];
  alternates: { locale: LocaleValues; href: string }[];
  localeSwitch: {
    currentLocale: LocaleValues;
    targetLocale: LocaleValues;
    href: string;
    missingTranslation: boolean;
  };
};

const { data, readingTime, slug } = post;
const {
  draft,
  title,
  publishDate,
  updatedDate,
  description,
  heroImage,
  heroAlt,
  noHero,
  category,
  tags = [],
} = data;

const { Content } = await render(post as PostCollection);

const postMetaProps = {
  category,
  publishDate,
  readingTime,
  updatedDate,
};

const getTransitionNameFromElementId = setTransitionSlug({ pageSlug: slug });

const metadata: Metadata = {
  title,
  description,
};
const currentPath = getPostPath(post.locale, slug);
---

<PostLayout {metadata} {alternates} {localeSwitch} currentLocale={post.locale} currentPath={currentPath}>
  <Fragment slot="hero-image">
    {
      !noHero && (
        <div class="w-full h-full flex justify-center items-center">
          <div class="relative w-full">
            <Skeleton className="aspect-[16/8] border-outline" />
            <Image
              {...IMAGE_SIZES.REMOTE.POST_HERO}
              src={heroImage}
              alt={heroAlt}
              fetchpriority="high"
              itemprop="image"
              class="block max-w-full h-auto aspect-[16/8] object-cover border-outline absolute inset-0 bg-surface"
              loading="eager"
              transition:name={getTransitionNameFromElementId({
                elementId: TRANSITION_ELEMENT_IDS.POST_CARD.HERO_IMAGE,
              })}
            />
          </div>
        </div>
      )
    }
  </Fragment>

  <Fragment slot="hero-text">
    <h1
      class="b-h1"
      transition:name={getTransitionNameFromElementId({
        elementId: TRANSITION_ELEMENT_IDS.POST_CARD.TITLE,
      })}
    >
      {title}
      {draft && <sup class="text-red-500 ml-1">{DRAFT_TEXT}</sup>}
    </h1>

    {
      description && (
        <p
          class="font-normal text-content text-xl md:text-2xl mb-6 md:mb-8"
          transition:name={getTransitionNameFromElementId({
            elementId: TRANSITION_ELEMENT_IDS.POST_CARD.DESCRIPTION,
          })}
        >
          {description}
        </p>
      )
    }

    <PostMeta
      {...postMetaProps}
      transition:name={getTransitionNameFromElementId({
        elementId: TRANSITION_ELEMENT_IDS.POST_CARD.META,
      })}
    />
  </Fragment>

  <Fragment slot="content">
    <Content />
  </Fragment>

  <Fragment slot="after-content">
    <div class="flex justify-between items-start gap-6 flex-col md:flex-row b-h2-mb">
      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="px-3 py-1 text-sm bg-primary-container text-on-primary-container rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </Fragment>

  <Fragment slot="more-posts">
    <div class="mt-12">
      <h2 class="text-2xl font-bold mb-6">{m["components.blog.more_posts"]()}</h2>
      {
        randomPosts.length > 0 && (
          <div class="grid gap-6 md:grid-cols-2">
            {randomPosts.slice(0, 4).map((relatedPost) => (
              <div class="border border-outline rounded-lg p-4">
                <h3 class="font-semibold mb-2">
                  <a
                    href={getPostPath(relatedPost.locale, relatedPost.slug)}
                    class="hover:text-primary"
                  >
                    {relatedPost.data.title}
                  </a>
                </h3>
                <p class="text-sm text-content opacity-75 line-clamp-2">
                  {relatedPost.data.description}
                </p>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </Fragment>
</PostLayout>
