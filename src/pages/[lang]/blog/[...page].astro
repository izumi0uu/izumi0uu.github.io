---
import { getAllPostsWithReadingTime } from "@/modules/post/common";
import List from "@/layouts/List.astro";
import PostList from "@/components/app/blog/PostList.astro";
import { CONFIG_CLIENT } from "@/config/client";
import { ROUTES } from "@/constants/routes";
import { getPageMetadata } from "@/utils/content/metadata";
import { pickPaginationPropsFromPage } from "@/utils/content/pagination";
import { SUPPORTED_LOCALES } from "@/config/i18n";
import { getPathWithLocale } from "@/utils/routing/paths";

import type { LocaleAlternate, LocaleSwitchTarget, PaginationProps } from "@/types/common";
import type { LocaleValues } from "@/types/config";
import type { Post } from "@/types/post";
import type { GetStaticPathsOptions } from "astro";

function getBlogPagePath(locale: LocaleValues, pageNumber: number) {
  return pageNumber === 1
    ? getPathWithLocale(locale, ROUTES.BLOG)
    : getPathWithLocale(locale, `${ROUTES.BLOG}${pageNumber}/`);
}

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const getStaticBlogPagePath = (locale: LocaleValues, pageNumber: number) =>
    pageNumber === 1
      ? getPathWithLocale(locale, ROUTES.BLOG)
      : getPathWithLocale(locale, `${ROUTES.BLOG}${pageNumber}/`);
  const allPosts: Post[] = await getAllPostsWithReadingTime();
  const pageSize = CONFIG_CLIENT.PAGE_SIZE_POST_CARD;
  const postsByLocale = Object.fromEntries(
    SUPPORTED_LOCALES.map((locale) => [locale, allPosts.filter((post) => post.locale === locale)])
  ) as Record<LocaleValues, Post[]>;
  const getPageCount = (locale: LocaleValues) => Math.ceil(postsByLocale[locale].length / pageSize);

  const paths = [];

  for (const lang of SUPPORTED_LOCALES) {
    const localizedPosts = postsByLocale[lang];
    const targetLocale = SUPPORTED_LOCALES.find((locale) => locale !== lang) ?? lang;

    if (localizedPosts.length === 0) {
      const alternates = SUPPORTED_LOCALES.map((locale) => ({
        locale,
        href: getStaticBlogPagePath(locale, 1),
      }));

      paths.push({
        params: { lang },
        props: {
          posts: [],
          alternates,
          localeSwitch: {
            currentLocale: lang,
            targetLocale,
            href: getStaticBlogPagePath(targetLocale, 1),
            missingTranslation: false,
          },
        },
      });

      continue;
    }

    const paginatedPaths = paginate(localizedPosts, {
      pageSize,
      params: { lang },
    });

    paths.push(
      ...paginatedPaths.map((path) => {
        const currentPage = path.props.page.currentPage;
        const targetPageCount = getPageCount(targetLocale);
        const hasEquivalentTargetPage = currentPage === 1 || targetPageCount >= currentPage;
        const alternates = SUPPORTED_LOCALES.filter((locale) => {
          const localePageCount = getPageCount(locale);
          return currentPage === 1 || localePageCount >= currentPage;
        }).map((locale) => ({
          locale,
          href: getStaticBlogPagePath(locale, currentPage),
        }));

        return {
          params: path.params,
          props: {
            posts: path.props.page.data,
            paginationProps: pickPaginationPropsFromPage(path.props.page),
            alternates,
            localeSwitch: {
              currentLocale: lang,
              targetLocale,
              href: hasEquivalentTargetPage
                ? getStaticBlogPagePath(targetLocale, currentPage)
                : getStaticBlogPagePath(targetLocale, 1),
              missingTranslation: false,
            },
          },
        };
      })
    );
  }

  return paths;
}

const {
  posts,
  paginationProps,
  alternates,
  localeSwitch,
} = Astro.props as {
  posts: Post[];
  paginationProps?: PaginationProps;
  alternates: LocaleAlternate[];
  localeSwitch: LocaleSwitchTarget;
};

const metadata = getPageMetadata("lists/blog");
const currentLocale = Astro.params.lang as LocaleValues;
const currentPath = getBlogPagePath(currentLocale, paginationProps?.currentPage ?? 1);
---

<List {metadata} {paginationProps} {alternates} {localeSwitch} {currentLocale} currentPath={currentPath}>
  <PostList posts={posts} />
</List>
