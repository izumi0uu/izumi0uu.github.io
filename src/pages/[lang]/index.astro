---
import { Image } from "astro:assets";

import Centered from "@/layouts/Centered.astro";

import { QuickLinksSection } from "@/components/app/home/QuickLinksSection";
import { HeroBanner } from "@/components/app/home/HeroBanner";
import { FadeUpAnimation } from "@/components/react/ui/FadeUpAnimation";

import { getPageMetadata } from "@/utils/content/metadata";
import { getSupportedAlternates, getLocaleSwitchTarget } from "@/utils/routing/navigation";
import * as m from "@/paraglide/messages";
import { getPathWithLocale } from "@/utils/routing/paths";

import { SUPPORTED_LOCALES } from "@/config/i18n";
import { ROUTES } from "@/constants/routes";
import heroImage from "@/assets/images/hero-default.png";

import type { LocaleValues } from "@/types/config";

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({
    params: { lang },
  }));
}

const currentLocale = Astro.params.lang as LocaleValues;
const metadata = getPageMetadata("");
const alternates = getSupportedAlternates((locale) => getPathWithLocale(locale, ROUTES.HOME));
const localeSwitch = getLocaleSwitchTarget({ currentLocale, alternates });
const currentPath = getPathWithLocale(currentLocale, ROUTES.HOME);
const blogPath = getPathWithLocale(currentLocale, ROUTES.BLOG);

const quickLinks = [
  {
    name: m["components.navigation_menu.blog_link"](),
    href: getPathWithLocale(currentLocale, ROUTES.BLOG),
    icon: "↗",
  },
  {
    name: m["components.navigation_menu.project_link"](),
    href: getPathWithLocale(currentLocale, ROUTES.PROJECT),
    icon: "↗",
  },
  {
    name: m["components.navigation_menu.experience_link"](),
    href: getPathWithLocale(currentLocale, ROUTES.EXPERIENCE),
    icon: "↗",
  },
  {
    name: m["components.navigation_menu.about_link"](),
    href: getPathWithLocale(currentLocale, ROUTES.ABOUT),
    icon: "↗",
  },
];
---

<Centered
  {metadata}
  {alternates}
  {localeSwitch}
  {currentLocale}
  currentPath={currentPath}
  className="flex-col-layout first:gap-0 gap-8 md:gap-16"
>
  <!-- Hero Page Section -->
  <section
    id="hero-page-section"
    aria-label="hero-page-section"
    class="flex-col-layout mode-theme-switch bg-surface-container rounded-sm"
  >
    <div
      id="hero-page-wrapper"
      aria-label="hero-page-wrapper"
      class="grid grid-cols-1 lg:grid-cols-2 gap-8 p-4 min-h-[60vh] items-center"
    >
      <div id="hero-page-content" class="flex flex-col gap-4">
        <HeroBanner
          blogPath={blogPath}
          greeting={m["pages.home.hero_greeting"]()}
          rolePrefix={m["pages.home.hero_role_prefix"]()}
          rotatingTexts={[
            m["pages.home.hero_role_frontend"](),
            m["pages.home.hero_role_web"](),
            m["pages.home.hero_role_web3"](),
          ]}
          description={m["pages.home.hero_description"]()}
          ctaLabel={m["pages.home.hero_cta"]()}
          client:only="react"
        />
      </div>
      <div
        id="hero-page-image"
        aria-label="hero-page-image"
        class="hidden lg:flex items-center justify-center w-full h-full max-w-md max-h-[500px] mx-auto"
      >
        <Image
          src={heroImage}
          alt={m["pages.home.hero_greeting"]()}
          width={400}
          height={500}
          class="w-full h-auto object-contain rounded-lg shadow-lg"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- Quick Links Section -->
  <section id="quick-links" aria-label="quick-links" class="flex-col-layout mode-theme-switch">
    <FadeUpAnimation title={m["pages.home.quick_links_title"]()} client:visible>
      <QuickLinksSection links={quickLinks} client:only="react" />
    </FadeUpAnimation>
  </section>
</Centered>
