# Copy this file to `.env.production` when you need explicit production overrides.
# All values below are public build-time metadata for the static site.

SITE_URL=https://izumi0uu.com
PREVIEW_MODE=false

# Plausible analytics script URL, leave empty to disable analytics
PLAUSIBLE_SCRIPT_URL=

# Analytics domain override. Leave empty to derive it from SITE_URL.
PLAUSIBLE_DOMAIN=
